# ============================================================
# LiveKit Inbound Voice Agent — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to version control.
# ============================================================

# --- LiveKit Cloud ---
# Get these from https://cloud.livekit.io → your project → Settings → API Keys
LIVEKIT_URL=wss://your-project-name.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# --- Deepgram (Speech-to-Text) ---
# Get your API key from https://console.deepgram.com → API Keys
DEEPGRAM_API_KEY=your_deepgram_api_key
# Deepgram model. "nova-2" is recommended for phone calls.
STT_MODEL=nova-2

# --- Google Gemini (Language Model) ---
# Get your API key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key

# --- Google Model Selection ---
# Recommended: gemini-2.0-flash (free, fast) or gemini-2.5-flash (smarter)
GOOGLE_MODEL=gemini-2.0-flash

# --- Cartesia (Text-to-Speech) ---
# Get your API key from https://play.cartesia.ai → Settings → API Keys
CARTESIA_API_KEY=your_cartesia_api_key
# Find voice IDs at https://play.cartesia.ai/voices
CARTESIA_VOICE_ID=your_cartesia_voice_id

# --- Twilio (Inbound Phone / SIP) ---
# Get Auth Token from https://console.twilio.com → Account → API Keys & Tokens
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Your Twilio Account SID (starts with AC...)
TWILIO_ACCOUNT_SID=your_twilio_account_sid

# --- Airtable (Call Logging) ---
# Create a Personal Access Token at https://airtable.com/create/tokens
# Scopes needed: data.records:write, schema.bases:read
AIRTABLE_PAT=your_airtable_personal_access_token
# Your Airtable Base ID — found in the URL: https://airtable.com/appXXXXXXXXXXXXXX/...
AIRTABLE_BASE_ID=your_airtable_base_id
# Table name exactly as it appears in Airtable
AIRTABLE_TABLE_NAME=call_logs

# --- Agent Behaviour ---
# Maximum call duration in seconds before the agent politely ends the call.
# This prevents runaway API costs. Default: 600 (10 minutes)
MAX_CALL_DURATION_SECONDS=600

# --- Call Forwarding ---
# The phone number to transfer calls to when the caller asks to speak to a human.
# Must be in E.164 format (international dialling code + number, no spaces).
# Requires SIP REFER to be enabled on your Twilio SIP trunk.
TRANSFER_PHONE_NUMBER=+918529103161

# --- Agent Persona ---
# The system-level instructions that define the agent's personality and purpose.
# You can change this without touching code.
AGENT_SYSTEM_PROMPT=You are a friendly and professional assistant. Answer calls politely, help the caller with their inquiry, and keep responses concise and natural for a phone conversation.
